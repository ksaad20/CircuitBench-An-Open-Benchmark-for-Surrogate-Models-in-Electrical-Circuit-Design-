{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Hyperparameter Optimization\n",
    "\n",
    "This notebook performs reproducible hyperparameter optimization using Grid Search and Random Search.\n",
    "\n",
    "Workflow:\n",
    "- Load benchmark dataset\n",
    "- Train baseline model\n",
    "- Optimize hyperparameters\n",
    "- Compare optimization strategies\n",
    "- Evaluate final models\n",
    "- Export results"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import json\n",
    "from pathlib import Path\n",
    "\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "\n",
    "from sklearn.model_selection import (\n",
    "    GridSearchCV,\n",
    "    RandomizedSearchCV,\n",
    "    train_test_split\n",
    ")\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.metrics import mean_squared_error, r2_score\n",
    "\n",
    "SEED = 42"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Load Dataset"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "dataset_path = Path('../datasets/battery_management.csv')\n",
    "\n",
    "if dataset_path.exists():\n",
    "    df = pd.read_csv(dataset_path)\n",
    "else:\n",
    "    df = pd.DataFrame({\n",
    "        'Voltage': [3.65, 3.72, 3.81, 3.95, 4.05],\n",
    "        'Current': [2.1, 1.8, 1.5, 1.1, 0.8],\n",
    "        'Temperature': [25, 27, 29, 31, 34],\n",
    "        'SOC': [18, 35, 54, 76, 95]\n",
    "    })\n",
    "\n",
    "df.head()"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "X = df.drop(columns=['SOC'])\n",
    "y = df['SOC']\n",
    "\n",
    "X_train, X_test, y_train, y_test = train_test_split(\n",
    "    X,\n",
    "    y,\n",
    "    test_size=0.2,\n",
    "    random_state=SEED\n",
    ")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Baseline Model"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "baseline_model = RandomForestRegressor(\n",
    "    random_state=SEED\n",
    ")\n",
    "\n",
    "baseline_model.fit(X_train, y_train)\n",
    "\n",
    "baseline_predictions = baseline_model.predict(X_test)\n",
    "\n",
    "baseline_rmse = np.sqrt(\n",
    "    mean_squared_error(y_test, baseline_predictions)\n",
    ")\n",
    "\n",
    "baseline_r2 = r2_score(\n",
    "    y_test,\n",
    "    baseline_predictions\n",
    ")\n",
    "\n",
    "print('Baseline RMSE:', baseline_rmse)\n",
    "print('Baseline R²:', baseline_r2)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Hyperparameter Search Space"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "parameter_grid = {\n",
    "    'n_estimators': [50, 100, 200, 300],\n",
    "    'max_depth': [None, 5, 10, 20],\n",
    "    'min_samples_split': [2, 5, 10],\n",
    "    'min_samples_leaf': [1, 2, 4],\n",
    "    'max_features': ['sqrt', 'log2']\n",
    "}\n",
    "\n",
    "parameter_grid"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Grid Search"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "grid_search = GridSearchCV(\n",
    "    estimator=RandomForestRegressor(random_state=SEED),\n",
    "    param_grid=parameter_grid,\n",
    "    scoring='neg_root_mean_squared_error',\n",
    "    cv=5,\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "grid_search.fit(X_train, y_train)\n",
    "\n",
    "best_grid_model = grid_search.best_estimator_\n",
    "\n",
    "grid_predictions = best_grid_model.predict(X_test)\n",
    "\n",
    "grid_rmse = np.sqrt(\n",
    "    mean_squared_error(y_test, grid_predictions)\n",
    ")\n",
    "\n",
    "grid_r2 = r2_score(\n",
    "    y_test,\n",
    "    grid_predictions\n",
    ")\n",
    "\n",
    "print(grid_search.best_params_)\n",
    "print(grid_rmse)\n",
    "print(grid_r2)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Random Search"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "random_search = RandomizedSearchCV(\n",
    "    estimator=RandomForestRegressor(random_state=SEED),\n",
    "    param_distributions=parameter_grid,\n",
    "    n_iter=20,\n",
    "    cv=5,\n",
    "    random_state=SEED,\n",
    "    scoring='neg_root_mean_squared_error',\n",
    "    n_jobs=-1\n",
    ")\n",
    "\n",
    "random_search.fit(X_train, y_train)\n",
    "\n",
    "best_random_model = random_search.best_estimator_\n",
    "\n",
    "random_predictions = best_random_model.predict(X_test)\n",
    "\n",
    "random_rmse = np.sqrt(\n",
    "    mean_squared_error(y_test, random_predictions)\n",
    ")\n",
    "\n",
    "random_r2 = r2_score(\n",
    "    y_test,\n",
    "    random_predictions\n",
    ")\n",
    "\n",
    "print(random_search.best_params_)\n",
    "print(random_rmse)\n",
    "print(random_r2)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Performance Comparison"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "comparison = pd.DataFrame(\n",
    "    {\n",
    "        'Model': [\n",
    "            'Baseline',\n",
    "            'Grid Search',\n",
    "            'Random Search'\n",
    "        ],\n",
    "        'RMSE': [\n",
    "            baseline_rmse,\n",
    "            grid_rmse,\n",
    "            random_rmse\n",
    "        ],\n",
    "        'R2': [\n",
    "            baseline_r2,\n",
    "            grid_r2,\n",
    "            random_r2\n",
    "        ]\n",
    "    }\n",
    ")\n",
    "\n",
    "comparison"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Feature Importance"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "importance = pd.DataFrame(\n",
    "    {\n",
    "        'Feature': X.columns,\n",
    "        'Importance': best_grid_model.feature_importances_\n",
    "    }\n",
    ")\n",
    "\n",
    "importance = importance.sort_values(\n",
    "    by='Importance',\n",
    "    ascending=False\n",
    ")\n",
    "\n",
    "importance"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Export Reports"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "output_dir = Path('results')\n",
    "output_dir.mkdir(exist_ok=True)\n",
    "\n",
    "comparison.to_csv(\n",
    "    output_dir / 'optimization_results.csv',\n",
    "    index=False\n",
    ")\n",
    "\n",
    "importance.to_csv(\n",
    "    output_dir / 'feature_importance.csv',\n",
    "    index=False\n",
    ")\n",
    "\n",
    "report = {\n",
    "    'baseline_rmse': float(baseline_rmse),\n",
    "    'baseline_r2': float(baseline_r2),\n",
    "    'grid_rmse': float(grid_rmse),\n",
    "    'grid_r2': float(grid_r2),\n",
    "    'random_rmse': float(random_rmse),\n",
    "    'random_r2': float(random_r2),\n",
    "    'best_grid_parameters': grid_search.best_params_,\n",
    "    'best_random_parameters': random_search.best_params_\n",
    "}\n",
    "\n",
    "with open(output_dir / 'optimization_report.json', 'w') as f:\n",
    "    json.dump(report, f, indent=4)\n",
    "\n",
    "print('Reports successfully exported.')"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Reproducibility Summary\n",
    "\n",
    "- Random seed fixed to 42.\n",
    "- Five-fold cross-validation used.\n",
    "- Grid Search and Random Search compared.\n",
    "- Optimization results exported to CSV and JSON.\n",
    "- Feature importance exported.\n",
    "- Notebook generated for CircuitBench benchmark evaluation."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "print('Hyperparameter optimization completed successfully.')\n",
    "print('\\nPerformance Summary')\n",
    "print(comparison)\n",
    "\n",
    "print('\\nTop Features')\n",
    "print(importance.head())"
   ]
  }
 ],
